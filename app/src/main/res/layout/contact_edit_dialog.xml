<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/dlgSelectedContactTextView"
        android:layout_gravity="center"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:text=""
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/signup_content_margin">

        <com.payoda.countrydialcode.CountryCodePicker
            android:id="@+id/dlgContactCountryCodePicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/signup_content_margin"
            android:paddingStart="3dp"
            android:paddingTop="5dp"
            android:paddingEnd="3dp"
            android:paddingBottom="5dp"
            app:ccp_autoDetectCountry="true"
            app:ccp_contentColor="@color/black"
            app:ccp_countryAutoDetectionPref="SIM_NETWORK_LOCALE"
            app:ccp_showNameCode="false"
            app:ccp_textSize="16sp"
            />
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/dlgContactMobileWrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/dlgContactMobileEditText"
                style="@style/EditTextSelector"
                android:digits="0123456789"
                android:hint="@string/signup_mobile_hint"
                android:inputType="phone"
                android:maxLength="15" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
</LinearLayout>
